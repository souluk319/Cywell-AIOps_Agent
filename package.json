{
  "name": "cywell-ai-sentinel",
  "version": "0.1.4",
  "private": true,
  "description": "Cywell AI Sentinel - OpenShift-native evidence-based AIOps agent.",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run -w @cywell-ai-sentinel/console-plugin build",
    "dev:gateway": "npm run -w @cywell-ai-sentinel/gateway dev",
    "dev:console-plugin": "npm run -w @cywell-ai-sentinel/console-plugin serve",
    "verify": "npm run verify:contracts && npm run verify:gateway && npm run verify:knowledge-engine && npm run verify:gateway:brain && npm run verify:openshift:evidence && npm run verify:console-plugin && npm run verify:console:launcher-dom:built && npm run verify:console:topology-dom:built && npm run verify:console:integration:built && npm run verify:crc:connection:preview && npm run verify:pbs:live-prereqs && npm run verify:pbs:cutover-bundle && npm run verify:pbs:source-contract:required && npm run verify:deploy:manifests",
    "verify:contracts": "node ./scripts/verify-contracts.mjs",
    "verify:gateway": "node ./scripts/verify-gateway-mock.mjs",
    "verify:gateway:mock": "node ./scripts/verify-gateway-mock.mjs",
    "verify:knowledge-engine": "node ./scripts/verify-knowledge-engine.mjs",
    "verify:gateway:brain": "node ./scripts/verify-gateway-brain.mjs",
    "verify:openshift:evidence": "node ./scripts/verify-openshift-evidence.mjs",
    "verify:console-plugin": "npm run -w @cywell-ai-sentinel/console-plugin build",
    "verify:console:launcher-dom": "npm run verify:console-plugin && npm run verify:console:launcher-dom:built",
    "verify:console:launcher-dom:built": "node ./scripts/verify-console-launcher-dom.mjs --require-browser",
    "verify:console:topology-dom": "npm run verify:console-plugin && npm run verify:console:topology-dom:built",
    "verify:console:topology-dom:built": "node ./scripts/verify-console-topology-dom.mjs --require-browser",
    "verify:console:topology-dom:optional": "npm run verify:console-plugin && node ./scripts/verify-console-topology-dom.mjs",
    "verify:console:integration": "npm run verify:console-plugin && npm run verify:console:integration:built",
    "verify:console:integration:built": "node ./scripts/verify-console-integration.mjs",
    "verify:crc:connection": "node ./scripts/verify-crc-connection.mjs --require-cluster",
    "verify:crc:connection:preview": "node ./scripts/verify-crc-connection.mjs",
    "verify:crc:deployment": "node ./scripts/verify-crc-deployment.mjs",
    "verify:pbs:preflight": "node ./scripts/verify-pbs-preflight.mjs",
    "verify:pbs:preflight:shadow": "node ./scripts/verify-pbs-preflight.mjs --overlay=pbs-shadow",
    "verify:pbs:preflight:shadow:cluster": "node ./scripts/verify-pbs-preflight.mjs --overlay=pbs-shadow --require-cluster",
    "verify:pbs:preflight:live:preapply": "node ./scripts/verify-pbs-preflight.mjs --require-cluster --require-secret --skip-applied",
    "verify:pbs:preflight:live": "node ./scripts/verify-pbs-preflight.mjs --require-cluster --require-secret",
    "verify:pbs:preflight:live:site:preapply": "node ./scripts/verify-pbs-preflight.mjs --require-cluster --require-secret --skip-applied --overlay-path=test-results/pbs-live-prereqs/pbs-live-site",
    "verify:pbs:preflight:live:site": "node ./scripts/verify-pbs-preflight.mjs --require-cluster --require-secret --overlay-path=test-results/pbs-live-prereqs/pbs-live-site",
    "verify:pbs:live": "node ./scripts/verify-pbs-live-smoke.mjs",
    "verify:pbs:cutover": "node ./scripts/verify-pbs-live-smoke.mjs --cutover",
    "verify:pbs:cutover:cluster": "npm run verify:pbs:preflight:live:site && node ./scripts/verify-pbs-live-smoke.mjs --cutover --cluster",
    "verify:release:source-pinning": "node ./scripts/verify-pbs-source-contract.mjs --require-source --require-clean-source --require-expected-head",
    "verify:release": "npm run verify:release:pbs-live",
    "verify:release:pbs-live": "npm run verify:release:source-pinning && npm run verify:pbs:preflight:live:site:preapply && node ./scripts/render-pbs-cutover-bundle.mjs --require-live-ready && npm run verify:pbs:preflight:live:site && node ./scripts/verify-pbs-live-smoke.mjs --cutover --cluster",
    "render:pbs:live-prereqs": "node ./scripts/render-pbs-live-prereqs.mjs",
    "render:pbs:live-prereqs:template": "node ./scripts/render-pbs-live-prereqs.mjs --write-input-template",
    "verify:pbs:live-prereqs": "node ./scripts/render-pbs-live-prereqs.mjs --self-test",
    "render:pbs:cutover-bundle": "node ./scripts/render-pbs-cutover-bundle.mjs",
    "verify:pbs:cutover-bundle": "node ./scripts/render-pbs-cutover-bundle.mjs --self-test",
    "verify:pbs:source-contract": "node ./scripts/verify-pbs-source-contract.mjs",
    "verify:pbs:source-contract:required": "node ./scripts/verify-pbs-source-contract.mjs --require-source",
    "deploy:crc": "node ./scripts/deploy-crc-dev.mjs",
    "release:crc:v0.1.4": "node ./scripts/promote-crc-release-images.mjs",
    "verify:deploy:manifests": "node ./scripts/verify-deploy-manifests.mjs"
  },
  "dependencies": {
    "@openshift-console/dynamic-plugin-sdk": "4.19.1",
    "@openshift-console/dynamic-plugin-sdk-webpack": "4.19.0",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "playwright-core": "^1.61.1",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "webpack-cli": "^5.1.4"
  }
}
